{
  "bundle": {
    "targets": ["deb", "rpm", "appimage"],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2"
        ],
        "section": "utils"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libappindicator-gtk3",
          "librsvg2"
        ],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
