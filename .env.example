OLLAMA_URL=http://127.0.0.1:11434
# Optional: preselect a chat model by name. Leave blank to choose per thread in Atlas.
CHAT_MODEL=
# Leave blank to use the selected model's default temperature behavior.
CHAT_TEMPERATURE=
EMBED_MODEL=nomic-embed-text:latest
QDRANT_PATH=.data/qdrant
MEM0_COLLECTION=atlas_local_memory
EMBED_DIM=768
LANGGRAPH_CHECKPOINT_DB=.data/langgraph/checkpoints.sqlite
MEM0_HISTORY_DB=.data/mem0_history.sqlite
MEMORY_TOP_K=5
